generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Widyaiswara {
  id            String   @id @map("_id")
  nip           String   @unique
  name          String
  gelar         String   @default("")
  email         String   @unique
  jabatan       String
  level         Int
  level_label   String
  jp_last_month Int      @default(0)
  password_hash String?
  password_plain String  @default("wi123")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
}

model KategoriPelatihan {
  id         String   @id @map("_id")
  name       String
  kepanjangan String  @default("")
  min_weight Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
}

model MataPelatihan {
  id          String   @id @map("_id")
  name        String
  kategori_id String
  jp_total    Int
  min_jp      Int      @default(2)
  max_jp      Int      @default(6)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model Lokasi {
  id        String   @id @map("_id")
  name      String
  alamat    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Pelatihan {
  id          String   @id @map("_id")
  name        String
  kategori_id String
  pola        String
  start_date  String
  end_date    String
  lokasi_id   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model JadwalSesi {
  id              String   @id @map("_id")
  batch_id        String
  mapel_id        String
  wi_ids          String[]
  date            String
  start_time      String
  end_time        String
  format          String
  lokasi_id       String?
  jp_ke           String
  jp_count        Int
  detail_kegiatan String   @default("")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
}

model AdminConfig {
  id           String   @id @default("admin-config") @map("_id")
  passwordHash String   @map("passwordHash")
  primaryColor String   @default("221 83% 53%") @map("primaryColor")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}
